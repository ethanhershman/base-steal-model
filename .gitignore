# Generated data (regenerate with fetch_retrosheet.py + the parser). The raw
# 2023 Retrosheet files and the sample outputs ARE committed so the repo runs
# out of the box; every other season is ignored so a fetch of a decade of
# history (e.g. for win_probability.py's extended hold-only baseline)
# doesn't bloat the repo.
data/retrosheet_*/
!data/retrosheet_2023/
data/statcast/

# Full plate-appearance-level batting lines (~14MB/season, one row per PA
# rather than one row per steal attempt) -- regenerate with
# `retrosheet_parser.py --batting-out`, too large to commit.
data/sample/battinglines_*.csv
